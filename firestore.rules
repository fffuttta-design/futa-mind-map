rules_version = '2';

// FutaMindMap Firestore セキュリティルール
// - maps: 所有者のみ読み書き。公開マップ(isPublic)は誰でも閲覧可(共有ページ用)。
// - maps/{id}/history: 親マップの所有者のみ。
// - ai_usage: ログインユーザーは読み取り可(コスト表示)。書き込みは Functions(管理SDK)のみ。
service cloud.firestore {
  match /databases/{database}/documents {

    // マインドマップ本体
    match /maps/{mapId} {
      // 自分のマップ、または公開中マップは読める
      allow read: if (resource.data.isPublic == true)
                  || (request.auth != null && request.auth.uid == resource.data.ownerId);

      // 作成は本人を ownerId にする場合のみ
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.ownerId;

      // 更新・削除は所有者のみ
      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.ownerId;

      // バージョン履歴サブコレクション(親マップの所有者のみ)
      match /history/{historyId} {
        allow read, write: if request.auth != null
          && get(/databases/$(database)/documents/maps/$(mapId)).data.ownerId == request.auth.uid;
      }
    }

    // AI 利用料の月次集計(読み取り=ログインユーザー、書き込み=Functionsのみ)
    match /ai_usage/{ym} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
