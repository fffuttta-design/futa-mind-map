{
  "name": "futa-mind-map-desktop",
  "version": "1.2.1",
  "description": "FutaMindMap Windows Desktop App (Portable)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "icon": "node generate-icon.mjs",
    "build": "electron-builder --win --publish never"
  },
  "build": {
    "appId": "com.futamindmap.desktop",
    "productName": "FutaMindMap",
    "copyright": "Copyright © 2025 FutaMindMap",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "build/**"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "portable": {
      "artifactName": "FutaMindMap.exe"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "png-to-ico": "^2.1.8"
  }
}
