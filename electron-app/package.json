{
  "name": "futa-mind-map-desktop",
  "version": "1.1.0",
  "description": "FutaMindMap Windows Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "icon": "node generate-icon.mjs",
    "build": "electron-builder --win",
    "release": "electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.futamindmap.desktop",
    "productName": "FutaMindMap",
    "copyright": "Copyright © 2025 FutaMindMap",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "fffuttta-design",
        "repo": "futa-mind-map",
        "releaseType": "release"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "build/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FutaMindMap",
      "installerLanguages": [
        "ja"
      ]
    }
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "png-to-ico": "^2.1.8"
  }
}
